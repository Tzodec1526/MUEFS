# Michigan Unified E-Filing System - Environment Configuration

# Database
DATABASE_URL=postgresql+asyncpg://muefs:muefs_dev@postgres:5432/muefs
DATABASE_URL_SYNC=postgresql://muefs:muefs_dev@postgres:5432/muefs
POSTGRES_USER=muefs
POSTGRES_PASSWORD=muefs_dev
POSTGRES_DB=muefs

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=muefs_minio
MINIO_ROOT_PASSWORD=muefs_minio_secret
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=muefs_minio
S3_SECRET_KEY=muefs_minio_secret
S3_BUCKET_NAME=muefs-documents

# Keycloak
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=muefs
KEYCLOAK_CLIENT_ID=muefs-api
KEYCLOAK_CLIENT_SECRET=change-me-in-production
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Backend
SECRET_KEY=change-this-to-a-random-secret-in-production
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend
VITE_API_URL=http://localhost:8000
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=muefs
VITE_KEYCLOAK_CLIENT_ID=muefs-frontend

# Email (notifications)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@michigan-efiling.gov

# Document Processing
MAX_FILE_SIZE_MB=100
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
